NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AI/LLM (나경 — 프로모션 인사이트 등)
# 쿠팡 SKU 분석 등(미설정 시 claude-haiku-4-5)
# ANTHROPIC_ANALYSIS_MODEL=claude-haiku-4-5-20251001

# 쿠팡 API (나경 — 프로모션/판매 데이터 수집)
COUPANG_ACCESS_KEY=
COUPANG_SECRET_KEY=
COUPANG_VENDOR_ID=

# 윙 (쿠팡 셀러 포털 — 나경)
WING_ID=
WING_PW=

# 기상청 API (진희 logistics)
KMA_SERVICE_KEY=

# 네이버 DataLab API (지호 — 핫팩 시즌 키워드 축)
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# LLM 모델 분리 (지호 — 핫팩 시즌 대시보드 기능별)
# 튜닝 제안(시즌 is_closed 전환 시, 구조적 판단) — 기본 Opus
# ANTHROPIC_TUNING_MODEL=claude-opus-4-7
# 시즌 브리프(주간 서술 리포트) — 기본 Sonnet
# ANTHROPIC_SEASON_BRIEF_MODEL=claude-sonnet-4-6

# (선택) 기타 Postgres 도구용. 밀크런·allocations API 는 NEXT_PUBLIC_SUPABASE_* 만 사용합니다.
DATABASE_URL=

# 이카운트 OAPI — 3법인 세분화 (슬아 scripts/ecount_crawler.py --company gl|glpharm|hnb|all)
ECOUNT_GL_COM_CODE=
ECOUNT_GL_USER_ID=
ECOUNT_GL_USER_PW=
ECOUNT_GL_API_KEY=
ECOUNT_GL_PURCHASE_LIST_PATH=/OAPI/V2/Purchases/GetListPurchases
# ECOUNT_GL_PURCHASE_MENU_SEQ=  # 구매현황 메뉴 트리가 다를 때만 설정
# ECOUNT_GL_PURCHASE_PRG_ID=

ECOUNT_GLPHARM_COM_CODE=
ECOUNT_GLPHARM_USER_ID=
ECOUNT_GLPHARM_USER_PW=
ECOUNT_GLPHARM_API_KEY=
ECOUNT_GLPHARM_PURCHASE_LIST_PATH=/OAPI/V2/Purchases/GetListPurchases

ECOUNT_HNB_COM_CODE=
ECOUNT_HNB_USER_ID=
ECOUNT_HNB_USER_PW=
ECOUNT_HNB_API_KEY=
ECOUNT_HNB_PURCHASE_LIST_PATH=/OAPI/V2/Purchases/GetListPurchases

EXCHANGE_RATE_KEY=
KMA_SERVICE_KEY=
final_key=
final_api_key=

# 이카운트 OAPI — 단일 계정 (진희 /api/crawl/ecount 엔드포인트, 물류 총재고현황)
# NOTE: 위 3법인 세분화(슬아)와 병존. 진희 크롤러는 .env.local의 ECOUNT_COMPANY_CODE/USER_ID/PASSWORD 사용.
# ERP_ZONE: 이카운트 ZONE 조회값(예: CC). 테스트망은 ERP_USE_SBOAPI=true
# ERP_WH_CD: 창고코드(선택, 비우면 전체)
# ERP_COM_CODE=
# ERP_USER_ID=
# ERP_API_KEY=
# ERP_ZONE=
# ERP_WH_CD=
# ERP_USE_SBOAPI=false
# CRAWL_DRY_RUN=true  # true면 크롤링/파싱만 검증하고 DB 저장은 생략

# 로컬 품목 마스터 엑셀 경로 (총재고현황 품목코드/품목명 매핑)
# 권장: 프로젝트 내부 경로 사용 (외부 경로는 실행 환경에 따라 접근 차단 가능)
# PRODUCT_MASTER_XLSX_PATH=C:/Users/user/Desktop/GL/gl-dashboard/src/components/logistics/_data/품목코드_매핑결과.xlsx
