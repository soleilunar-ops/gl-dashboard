NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
FASTAPI_URL=http://localhost:8000

# AI/LLM (나경 — 프로모션 인사이트 등)
ANTHROPIC_API_KEY=

# 쿠팡 API (나경 — 프로모션/판매 데이터 수집)
COUPANG_ACCESS_KEY=
COUPANG_SECRET_KEY=
COUPANG_VENDOR_ID=

# 윙 (쿠팡 셀러 포털 — 나경)
WING_ID=
WING_PW=

# 기상청 API (정민 forecast / 진희 logistics)
KMA_SERVICE_KEY=

# 이카운트 OAPI (물류 총재고현황 — 서버 액션, 클라이언트에 노출 금지)
# ERP_ZONE: 이카운트 ZONE 조회값(예: CC). 테스트망은 ERP_USE_SBOAPI=true
# ERP_WH_CD: 창고코드(선택, 비우면 전체)
# ERP_COM_CODE=
# ERP_USER_ID=
# ERP_API_KEY=
# ERP_ZONE=
# ERP_WH_CD=
# ERP_USE_SBOAPI=false
# CRAWL_DRY_RUN=true  # true면 크롤링/파싱만 검증하고 DB 저장은 생략

# 로컬 품목 마스터 엑셀 경로 (총재고현황 품목코드/품목명 매핑)
# 권장: 프로젝트 내부 경로 사용 (외부 경로는 실행 환경에 따라 접근 차단 가능)
# PRODUCT_MASTER_XLSX_PATH=C:/Users/user/Desktop/GL/gl-dashboard/src/components/logistics/_data/품목코드_매핑결과.xlsx

# import_leadtime 테이블 없을 때 리드타임 UI·/api/tracking 만 검증 (true → DB 호출 안 함)
# NEXT_PUBLIC_LEADTIME_MOCK=true
