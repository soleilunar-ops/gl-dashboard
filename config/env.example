# 아래 파일을 복사해 프로젝트 루트에 .env 로 저장하고 값만 채운다.
#   copy config\env.example .env   (Windows)
# 값이 있는 .env / .ecmwfapirc 는 git 에 올리지 않는다 (.gitignore 참고).

# --- 기상청 공공데이터 (data.go.kr decoding 키) ---
KMA_API_KEY=c43aa2315aced127441e7f92433ada07c3e0a62d6cae186904dd75b13f1e4571

# --- ECMWF CDS / API (S2S 등, 16~46일 계열에 사용 시) ---
# 또는 홈 디렉터리에 ~/.ecmwfapirc 배치 (이 레포에는 넣지 않음)
ECMWF_URL=https://api.ecmwf.int/v1
ECMWF_KEY=
ECMWF_EMAIL=

# --- 기타 ---
CDS_API_TOKEN=
OPENAI_API_KEY=

# --- Open-Meteo / 관측 지점 (한 지점만 쓸 때 예시) ---
WEATHER_LAT=37.5665
WEATHER_LON=126.9780
